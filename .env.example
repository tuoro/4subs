APP_SECRET=replace-with-strong-random-string

TRANSLATION_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

ASR_PROVIDER=openai-compatible
ASR_BASE_URL=https://api.openai.com/v1
ASR_API_KEY=
ASR_MODEL=whisper-1

OCR_PROVIDER=openai-compatible-vision
OCR_BASE_URL=https://api.openai.com/v1
OCR_API_KEY=
OCR_MODEL=gpt-4.1-mini
OCR_FRAME_INTERVAL_MS=1000
OCR_CROP_TOP_PERCENT=72
OCR_CROP_HEIGHT_PERCENT=22

FFMPEG_BIN=ffmpeg
WORK_DIR=/app/work
JOB_CONCURRENCY=2

# 宿主机媒体目录，会映射到容器内 /media
MEDIA_HOST_PATH=./media
